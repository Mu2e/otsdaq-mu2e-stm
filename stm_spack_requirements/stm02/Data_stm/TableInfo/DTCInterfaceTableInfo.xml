				<COLUMN Type="Data" 	 Name="EventBuilderMACIndex" 	 StorageName="EVENT_BUILDER_MAC_INDEX" 		DataType="NUMBER" 		DataChoices="" 		MinValue="0" 		MaxValue="255"/>
				<COLUMN Type="Data" 	 Name="EventBuilderNumBuff" 	 StorageName="EVENT_BUILDER_NUM_BUFF" 		DataType="NUMBER" 		DataChoices="" 		MinValue="0" 		MaxValue="127"/>
				<COLUMN Type="Data" 	 Name="EventBuilderStartNode" 	 StorageName="EVENT_BUILDER_START_NODE" 		DataType="NUMBER" 		DataChoices="" 		MinValue="0" 		MaxValue="127"/>
				<COLUMN Type="Data" 	 Name="EventBuilderNumNodes" 	 StorageName="EVENT_BUILDER_NUM_NODES" 		DataType="NUMBER" 		DataChoices="" 		MinValue="0" 		MaxValue="127"/>
