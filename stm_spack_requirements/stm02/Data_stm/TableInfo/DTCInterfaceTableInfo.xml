	<ROOT xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="TableInfo.xsd">
		<TABLE Name="DTCInterfaceTable">
			<VIEW Name="DTC_INTERFACE_TABLE" Type="File,Database,DatabaseTest" Description="Each%20record%20in%20this%20table%20represents%20a%20Data%20Transfer%20Controller%20(DTC)%20front-end%20instance.%20The%20full%20DTC%20User%20Guide%20can%20be%20found%20at%20mu2edocdb%204097.%20%0A%0AThere%20is%20a%20DTC%20table%20schema%20for%20stand-alone%20DTC%2FROC%20development%20in%20otsdaq-mu2e-config%2FCoreTables%2C%20and%20the%20full%20parameter%20DTC%20table%20schema%20in%20otsdaq-mu2e-config%2FCoreTables%2FAdvanced.%20%0A%0A%0AHere%20are%20some%20notes%20on%20particular%20fields%3A%0A%09-%20%3Cb%3EUID%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'UID'%20field%20is%20the%20unique%20ID%20for%20the%20DTC%20record.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEmulatorMode%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'EmulatorMode'%20field%2C%20when%20false%2C%20requires%20a%20DTC%20PCIe%20card%20to%20be%20installed%20and%20active%20in%20the%20node%20which%20instantiates%20this%20DTC%20front-end%20interface.%20When%20true%2C%20no%20hardware%20is%20required%20and%20a%20software%20based%20emulation%20is%20activated.%3C%2FINDENT%3E%0A%09-%20%3Cb%3ELocationInChain%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'LocationInChain'%20field%20is%20used%20to%20identify%20the%20location%20of%20the%20DTC%20in%20its%20CFO%20timing%20chain.%20Currently%2C%20the%20location%20in%20chain%20is%20not%20used%2C%20but%20it%20was%20in%20the%20past%20and%20may%20be%20in%20the%20future%20to%20assist%20with%20Loopback%20or%20maintaining%20timing%20chain%20lock.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EDeviceIndex%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'DeviceIndex'%20field%20identifies%20PCIe%20slot%20device%20index.%20Each%20Mu2e%20device%20(CFO%20or%20DTC)%20is%20assigned%20an%20incrementing%20DMA%20primary%20index.%20For%20example%2C%20if%20there%20are%202%20DTCs%20installed%20in%20a%20node%2C%20one%20will%20have%20index%200%20and%20one%20will%20have%20index%201.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEmulateCFO%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'EmulateCFO'%20field%20is%20a%20flag%20to%20enable%20or%20disable%20internal%20CFO%20emulation%20in%20the%20DTC.%20When%20using%20an%20external%20CFO%2C%20this%20should%20be%20false.%20When%20in%20Mu2e%20Global%20Event%20Building%20Mode%2C%20this%20flag%20is%20ignored%20and%20the%20DTC%20is%20setup%20to%20be%20in%20a%20timing%20chain.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EConfigureClock%3C%2Fb%3E%20%26%20%3Cb%3EJitterAttenuatorInputSource%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'ConfigureClock'%20enables%20a%20Jitter%20Attenuator%20(JA)%20reset%20during%20the%20configure%20transition%20based%20on%20the%20'JitterAttenuatorInputSource'%20field.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEnableROCConfigureStep%3C%2Fb%3E%20%26%20%3Cb%3ELinkToROCGroupTable%3C%2Fb%3E%20%26%20%3Cb%3ELinkToROCGroupID%3C%2Fb%3E%3A%0A%3CINDENT%3EThe%20'EnableROCConfigureStep'%20field%20is%20a%20flag%20to%20enable%20or%20disable%20running%20the%20children%20ROC(s)%20configure%20transition%20code%20based%20on%20the%20ROC%20front-end%20instance(s)%20specified%20by%20the%20'LinkToROCGroupTable'%20and%20the%20'LinkToROCGroupID'%20fields.%200-6%20children%20ROCs%20are%20allowed%20per%20DTC.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEnableSoftwareDataRequestMode%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'EnableSoftwareDataRequestMode'%20field%20is%20a%20flag%20to%20enable%20or%20disable%20Software%20Data%20Request%20Mode.%20When%20false%2C%20automatic%20Data%20Request%20generation%20at%20the%20DTC%20is%20enable.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEnableSoftwareDataRequestMode%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'EnableSoftwareDataRequestMode'%20field%20is%20a%20flag%20to%20enable%20or%20disable%20Software%20Data%20Request%20Mode.%20When%20false%2C%20automatic%20Data%20Request%20generation%20at%20the%20DTC%20is%20enable.%3C%2FINDENT%3E%0A%09-%20%3Cb%3EEventBuilder*%3A%3C%2Fb%3E%0A%3CINDENT%3EThe%20'EventBuilder*'%20fields%20are%20used%20to%20specify%20Hardware%20Event%20Building%20functionality.%20%3Cb%3E'EventBuilderDTCID'%3C%2Fb%3E%20in%20particular%20is%20used%20to%20identify%20DTC%20data%20streams%20in%20artdaq%20data%20analysis%20-%20the%20standard%20calculation%20is%20(nodeIndex%20x%202%20%2B%20DeviceIndex)%2C%20so%20e.g.%20for%20mu2edaq11%2Fdevice-1%20%3D%2011%20x%202%20%2B%201%20%3D%2023.%3C%2FINDENT%3E">
				<COLUMN Type="UID" 	 Name="UID" 	 StorageName="UID" 		DataType="STRING" 		DataChoices=""/>
