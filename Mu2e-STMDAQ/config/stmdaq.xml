<?xml version="1.0"?>
<stm>
  <!-- The data channel -->
  <channel>0</channel> <!-- 0=HPGe,1=LaBr -->
  <!-- Starting STMDAQ CPU core ID (for CPU utils) -->
  <stmdaq_starting_core>18</stmdaq_starting_core> <!-- Core ID will wrap around from max -->
  <stmdaq_cpu_socket>0</stmdaq_cpu_socket> <!-- Lock to NUMA node 0 -->
  <!-- Starting ARTDAQ CPU core ID (for CPU utils) -->
  <artdaq_starting_core>18</artdaq_starting_core> <!-- Core ID will wrap around from max -->
  <artdaq_cpu_socket>1</artdaq_cpu_socket> <!-- Lock to NUMA node 1 -->
  <!-- Firmware register parameters -->
  <fw>
    <fADC>300</fADC> <!-- ADC sampling frequency (MHz) -->
  </fw>
  <!-- Mu2e event parameters -->
  <mu2e>
    <min_event_period>1.675</min_event_period> <!-- Minimum event period (us) -->
    <on_spill_period>1.695</on_spill_period> <!-- On-spill event period (us) -->
    <off_spill_period>100</off_spill_period>  <!-- Off-spill event period (us) -->
  </mu2e>
  <!-- Parameters for file writing -->
  <write_data>
    <logfile>/stmdaq</logfile> <!-- Log file directory -->
    <write_dir>/data1/alexkesh</write_dir> <!-- Binary file data write directory -->
    <filename_prefix>mu2estm</filename_prefix> <!-- The filename prefix  -->
    <max_file_size>2</max_file_size> <!-- Maximum file size for each stream (GB)  -->
    <file_buffer>3</file_buffer> <!-- Number of buffered files -->
    <log_interval>5</log_interval> <!-- Write logging frequency (s) -->
  </write_data>
  <!-- Paramaters for data buffers and memory allocation -->
  <raw_buffer_size>10</raw_buffer_size> <!-- Set each raw buffer size in MB -->
  <struct_extra>5</struct_extra>  <!-- % allowance for headers, MWD, etc -->
  <queue_capacity>60</queue_capacity> <!-- Number of structs per ring buffer -->
  <buffer_pool_size>120</buffer_pool_size> <!-- Maximum number of ring buffers -->

  <!-- Operations: booleans to perform operation (0=false/1=true)-->
  <operations>
    <UDP>1 <!-- UDP class -->
     <receive_data>1</receive_data> 
    </UDP>
    <CheckData>1 <!-- CheckData class -->
      <check_packets>1</check_packets>
    </CheckData>
    <FormEvents>1 <!-- FormEvents class -->
      <get_events>1</get_events>
    </FormEvents>
    <ZeroSuppress>1 <!-- ZeroSuppress class -->
      <prep_data>1</prep_data>
      <find_peaks>1</find_peaks>
      <suppress_data>1</suppress_data>
    </ZeroSuppress>
    <MWD>0
    <deconv_and_diff>1</deconv_and_diff>
    <averaging>1</averaging>
     <find_peaks>0</find_peaks>
   </MWD> <!-- MWD class -->
   <WriteManager>1 <!-- Write Manager class -->
      <write_raw>0</write_raw>
      <write_zs>1</write_zs>
      <write_mwd>0</write_mwd>
    </WriteManager>
    <DQM>0 <!-- DQM class -->
      <update_dqm>1</update_dqm>
    </DQM>
  </operations>
  <!-- UDP parameters -->
  <udp>
    <recv_timeout_secs>10</recv_timeout_secs> <!-- UDP receive timeout (seconds) -->
    <recv_timeout_usecs>0</recv_timeout_usecs> <!-- UDP receive timeout (usecs) -->
    <poll_timeout_ms>100</poll_timeout_ms> <!-- UDP receive timeout (ms) -->
    <!-- HPGe UDP parameters -->
    <hpge> 
      <fw>  
        <ip>192.168.34.12</ip>
        <port>51872</port>
      </fw>
      <sw>
        <ip>192.168.34.12</ip>
        <port>51872</port>
      </sw>
    </hpge>
    <!-- LaBr UDP parameters -->
    <labr> 
      <fw>
        <ip>192.168.36.12</ip>
        <port>51874</port>
      </fw>
      <sw>
        <ip>127.0.0.3</ip>
        <port>10012</port>
      </sw>
    </labr>
  </udp>
  <!-- Zero Suppression -->
  <zs>
    <!-- HPGe ZS -->
    <hpge>
      <store_before_peak>1</store_before_peak> <!-- Time (us) to store before the peak -->
      <store_after_peak>2</store_after_peak> <!-- Time (us) to store after the peak -->
      <decay_time>200</decay_time> <!-- HPGe decay time constant (us) -->
      <grad_threshold>-200</grad_threshold> <!-- Gradient threshold -->
      <grad_window>100</grad_window> <!-- The gradient window in ADC values -->
      <n_avg>5</n_avg> <!-- Number of ADC values to average in the gradient -->
    </hpge>
    <!-- LaBr ZS -->
    <labr>
      <store_before_peak>0.15</store_before_peak> <!-- Time (us) to store before the peak -->
      <store_after_peak>0.3</store_after_peak> <!-- Time (us) to store after the peak -->
      <decay_time>0.15</decay_time> <!-- LaBr decay time constant (us) -->
      <grad_threshold>-100</grad_threshold> <!-- Gradient threshold -->
      <grad_window>13</grad_window> <!-- The gradient window in ADC values -->
      <n_avg>5</n_avg> <!-- Number of ADC values to average in the gradient -->
    </labr>
    <!-- ZS Detector Baseline Values -->
    <baseline>
      <use_last_value>1</use_last_value>
      <last_value>
        <mean>29.12</mean>
        <rms>27.86</rms>
      </last_value>
      <manual_value>
        <mean>0.00</mean>
        <rms>0.00</rms>
      </manual_value>
    </baseline>
  </zs>
  <!-- MWD -->
  <mwd>
    <M>512</M> <!-- MWD algorithm M value -->
    <L>256</L> <!-- MWD algorithm L value -->
    <hpge_tau>50</hpge_tau> <!-- HPGe decay time constant (us) -->
    <auxlow_init>4000</auxlow_init> <!-- minimum peak value, 4000 so l values always lower at start of peaks -->
    <use_fixed_cut>0</use_fixed_cut> <!-- Boolean: use fixed threshold cut? -->
    <fixed_cut_value>-500</fixed_cut_value> <!-- Fixed threshold cut value -->
    <nsigma_cut>3</nsigma_cut> <!-- Baseline cut as value sigmas from mean -->
    <thresholdgrad>-0.5</thresholdgrad> <!-- Peak finding threshold gradient -->
  </mwd>
  <!-- DQM -->
  <dqm>
    <raw_data>
      <raw_length>1000</raw_length>
    </raw_data>
    <baseline>
      <noise_length>10</noise_length>
    </baseline>
  </dqm>
</stm>
