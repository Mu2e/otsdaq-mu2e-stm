#Import common Makefile definitions
include $(STMDAQ_ROOT)/Makefile.inc

# turn off some warnings and compile with fPIC for shared object
CC_OPTS = -Wall
# -Wformat=2 -Wno-format-nonliteral -Wno-strict-aliasing -Wuninitialized -Wno-unused-function -Wextra -Wformat=2 -Wno-unused-parameter -Wno-missing-field-initializers -Wno-pointer-arith -Wno-unused-variable -Wno-unused-local-typedefs -Wno-parentheses -Wno-deprecated-declarations -Wno-conversion-null -Wno-unused-but-set-variable -Wno-type-limits -Wno-unused-but-set-parameter -Wno-catch-value -fPIC


INCLUDE_CC = -I$(ZMQ_INC) -I$(ROOT_INC)

all: $(BUILD_DIR)/bin/zeromq_test_server.exe $(BUILD_DIR)/bin/zeromq_test_client.exe

clean: 
	rm -rf $(BUILD_DIR)/obj/zeromq_test_server.o $(BUILD_DIR)/obj/zeromq_test_client.o

$(BUILD_DIR)/obj/zeromq_test_server.o :  zeromq_test_server.cc 
	echo "<**Compiling zeromq_test_server.cc**>"
	g++ -c $(CC_OPTS) $(INCLUDE_CC) zeromq_test_server.cc -o $(BUILD_DIR)/obj/zeromq_test_server.o

$(BUILD_DIR)/obj/zeromq_test_client.o :  zeromq_test_client.cc 
	echo "<**Compiling zeromq_test_client.cc**>"
	g++ -c $(CC_OPTS) $(INCLUDE_CC) zeromq_test_client.cc -o $(BUILD_DIR)/obj/zeromq_test_client.o

$(BUILD_DIR)/bin/zeromq_test_server.exe : $(BUILD_DIR)/obj/zeromq_test_server.o
	echo "<**Linking zeromq_test_server**>"
	echo "g++ $(BUILD_DIR)/obj/zeromq_test_server.o $(ZMQ_LIBS) -o $(BUILD_DIR)/bin/zeromq_test_server.exe"
	g++ $(BUILD_DIR)/obj/zeromq_test_server.o -L $(ZMQ_LIBS) $(ROOT_LIBS) -o $(BUILD_DIR)/bin/zeromq_test_server.exe

$(BUILD_DIR)/bin/zeromq_test_client.exe : $(BUILD_DIR)/obj/zeromq_test_client.o
	echo "<**Linking zeromq_test_client**>"
	echo "g++ $(BUILD_DIR)/obj/zeromq_test_client1.o $(ZMQ_LIBS) -o $(BUILD_DIR)/bin/zeromq_test_client.exe"
	g++ $(BUILD_DIR)/obj/zeromq_test_client.o -L $(ZMQ_LIBS) $(ROOT_LIBS) -o $(BUILD_DIR)/bin/zeromq_test_client.exe

