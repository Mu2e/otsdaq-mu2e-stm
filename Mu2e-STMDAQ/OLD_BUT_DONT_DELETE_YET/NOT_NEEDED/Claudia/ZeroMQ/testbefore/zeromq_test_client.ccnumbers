//  Hello World client
#include <iostream>
#include </work/zmq/include/zmq.h>
#include <string.h>
#include <stdio.h>
#include <unistd.h>
#include <vector>

//#include </work/root/include/TH1F.h>
//#include </work/root/include/TCanvas.h>
//#include </work/root/include/TRandom.h>


int main (void)
{
  printf ("Connecting to server…\n");
  void *context = zmq_ctx_new ();
  void *requester = zmq_socket (context, ZMQ_REQ);
  zmq_connect (requester, "tcp://localhost:5555");
  
  //TH1F*h1 = new TH1F("TH1","", 1000, -10, 10);
  

  int request_nbr, nbytes;
  for (request_nbr = 0; request_nbr != 2; request_nbr++) {
    //char buffer [800];
    int16_t buffer[512];
    if(request_nbr == 0){
      printf ("Get gaussian mean 1\n", request_nbr);
      zmq_send (requester, "Gaussian mean 1", 15, 0);
      nbytes = zmq_recv (requester, buffer, 1024, 0);
     
      for(int i=0;i<512;i++){
       std::cout<<buffer[i]<<std::endl;
      //h1->Fill(buffer[i]);
      }
      //h1->Draw();
      printf ("Received gaussian mean 1\n", request_nbr);
      //h1->Reset();
    }
    if(request_nbr == 0){
      printf ("Get gaussian mean 2\n", request_nbr);
      zmq_send (requester, "Gaussian mean 2", 15, 0);
      nbytes = zmq_recv (requester, buffer, 1024, 0);
     
      for(int i=0;i<512;i++){
       std::cout<<buffer[i]<<std::endl;
      //h1->Fill(buffer[i]);
      }
      //h1->Draw();
      printf ("Received gaussian mean 2\n", request_nbr);
      //h1->Reset();
    }
  }
  zmq_close (requester);
  zmq_ctx_destroy (context);
  return 0;
}
